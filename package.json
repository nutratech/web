    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0"
  },
  "jest": {
    "coveragePathIgnorePatterns": [
      "reportWebVitals.ts"
    ],
    "coverageThreshold": {
