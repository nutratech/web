root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true

indent_style = space
indent_size = 4
max_line_length = 100

# intellij/webstorm conflicts with prettier/eslint
ij_html_space_inside_empty_tag = true

ij_javascript_spaces_within_object_literal_braces = true
ij_javascript_keep_simple_methods_in_one_line = true


[*.js]
indent_size = 2
max_line_length = 100


[*.{ts,tsx}]
indent_size = 2
max_line_length = 100


[*.{css,scss}]
indent_size = 2
max_line_length = 100


[*.html]
indent_size = 2
max_line_length = 100


[*.json]
indent_size = 2
max_line_length = 120


[*.{yaml,yml}]
indent_size = 2
max_line_length = 80


[*.md]
max_line_length = 85


[Makefile]
indent_style = tab
max_line_length = 120


[{COMMIT_EDITMSG,MERGE_MSG,SQUASH_MSG,git-rebase-todo}]
max_line_length = 72
